<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.PurePlayer1">

        <activity
            android:name=".MiniPlayer"
            android:exported="false"
            android:label="@string/title_activity_mini_player"
            android:theme="@style/Theme.PurePlayer1" />
        <activity
            android:name=".PlayerState"
            android:exported="false"
            android:label="@string/title_activity_player_state"
            android:theme="@style/Theme.PurePlayer1" />
        <activity
            android:name=".Player"
            android:exported="false"
            android:label="@string/title_activity_player"
            android:theme="@style/Theme.PurePlayer1" />
        <activity
            android:name=".NavHostController"
            android:exported="false"
            android:label="@string/title_activity_nav_host_controller"
            android:theme="@style/Theme.PurePlayer1" />
        <activity
            android:name=".FavsActivity"
            android:exported="false"
            android:label="@string/title_activity_favs"
            android:theme="@style/Theme.PurePlayer1" />

        <activity
            android:name=".SearchActivity"
            android:exported="false"
            android:label="@string/title_activity_search"
            android:theme="@style/Theme.PurePlayer1" />
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:theme="@style/Theme.PurePlayer1">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
    </application>

</manifest>
